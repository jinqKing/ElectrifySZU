# ElectrifySZU local configuration example

DORM_API_BASE=http://192.168.84.3:9090/cgcSims
DORM_CLIENT=192.168.84.87
DORM_CAMPUS_NAME=深大新斋区

# Default room for demos: 深大新斋区 风槐斋 713.
DORM_BUILDING_ID=7126
DORM_BUILDING_NAME=风槐斋
DORM_ROOM_NAME=713

# Optional fallback. Users do not need to know this; the dashboard can discover it.
DORM_ROOM_ID=7322

DORM_POLL_INTERVAL=3600
DORM_LOW_POWER_THRESHOLD=20
HTTP_PROXY=

# Email alert subscriptions
SUBSCRIPTIONS_CSV=data/subscriptions.csv
ALERT_CHECK_TIME=08:00
ALERT_LOOP_INTERVAL=300
# Testing mode: ALERT_MODE=testing ignores check_time, runs every ALERT_TEST_INTERVAL seconds.
# In testing mode, SKIP_RECENT controls whether already-alerted-today subs get skipped.
# FORCE_SEND_ALERT bypasses the live electricity API and sends alerts unconditionally.
# FORCE_SEND_DAILY_REPORT similarly forces daily report emails.
# Both force flags only take effect when ALERT_MODE=testing.
# ALERT_MODE=production
# ALERT_TEST_INTERVAL=300
# SKIP_RECENT=1
# FORCE_SEND_ALERT=0
# FORCE_SEND_DAILY_REPORT=0

# 邮箱订阅域名白名单（逗号分隔，留空使用默认值：@email.szu.edu.cn,@mails.szu.edu.cn）
# ALLOWED_EMAIL_DOMAINS=@email.szu.edu.cn,@mails.szu.edu.cn

# Used in verification and unsubscribe links sent by email.
PUBLIC_BASE_URL=http://127.0.0.1:8000
ALERT_ADMIN_TOKEN=

# ── 结构化日志配置 ────────────────────────────────────────────────────────
# LOG_LEVEL       日志级别: DEBUG / INFO / WARNING / ERROR (默认 INFO)
# LOG_DIR         日志文件目录 (默认 logs/)
# LOG_MAX_BYTES   单个日志文件大小上限，单位字节 (默认 10485760 = 10MB)
# LOG_BACKUP_COUNT 保留的滚动备份文件数 (默认 5)
LOG_LEVEL=INFO
LOG_DIR=logs
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5


# ── 邮件内容与签名配置 ──
# 以下变量留空即不启用对应的自定义。
#
# EMAIL_SIGNATURE           追加到每封邮件正文末尾的一行落款（需含换行符 \n）
#                           例：\n—— 深圳大学电费预警系统
# EMAIL_SUBJECT_PREFIX      前置到每个邮件主题开头的标签（不含空格）
#                           例：[ElectrifySZU]
EMAIL_SIGNATURE=
EMAIL_SUBJECT_PREFIX=

# ── 测试邮件专用配置 ──
# test_delivery.py 会从以下变量读取默认值，可通过命令行参数覆盖。
TEST_RECIPIENT_EMAIL=test@example.com
TEST_EMAIL_SUBJECT=电费预警通知
TEST_EMAIL_CONTENT=这是一封测试邮件。
TEST_BUILDING_CAMPUS=粤海
TEST_BUILDING_NAME=风槐斋
TEST_ROOM_NAME=713
TEST_CLIENT_IP=192.168.84.87

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SSL=true
SMTP_STARTTLS=false
SENDER_EMAIL=warning@example.com
SENDER_PASSWORD=your_email_authorization_code
SENDER_NAME=电费预警系统
